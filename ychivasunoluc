  <div class="brand" style="color: #e74c3c; font-weight: bold; letter-spacing: 1px;">THE_RESILIENCE</div>
  <nav class="main-nav" aria-label="Điều hướng chính">
    <a href="#hero" style="color: white;">Trang chủ</a>
