  <title>MyWeb - 1. Gắn CSS ngoài</title>
  <link rel="stylesheet" href="../css/style.css">
</head>
<body>
<header class="site-header" id="top">
  <div class="brand">MyWeb</div>
  <nav class="main-nav" aria-label="Điều hướng chính">
